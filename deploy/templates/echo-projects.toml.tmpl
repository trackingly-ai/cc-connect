[echo]
server_url = "{{ECHO_SERVER_URL}}"
auth_token = "{{ECHO_WORKER_TOKEN}}"
register_on_start = true
host_id = "{{CC_HOST_ID}}"
label = "{{CC_HOST_LABEL}}"
org_id = "coding-team"
tags = ["local"]
heartbeat_interval_sec = 30

[[projects]]
name = "echo-manager-claude"

[projects.agent]
type = "claudecode"

[projects.agent.options]
work_dir = "{{ECHO_REPO_DIR}}"
mode = "{{CLAUDE_MANAGER_MODE}}"

[projects.echo]
enabled = true
role = "manager"

[[projects]]
name = "echo-architect-codex"

[projects.agent]
type = "codex"

[projects.agent.options]
work_dir = "{{ECHO_REPO_DIR}}"
